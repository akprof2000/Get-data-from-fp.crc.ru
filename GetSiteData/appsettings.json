{
  // ЕДИНЫЙ файл настроек всего конвейера: все четыре приложения лежат в одном
  // каталоге и читают отсюда СВОЮ секцию. Пути образуют сквозную цепочку:
  //
  //   GetSiteData → output/  →  ParseHTML → documents/  →
  //   MLTextToData → cells/ + other/  →  ParseTextHeader → OutputJson/ + OutputErrors/
  //
  // Любой ключ можно переопределить переменной окружения через «__», например:
  //   ParseTextHeader__Dadata__Token=…   GetSiteData__Search__PeriodEnd=12.2026

  // ── Общий корень рабочих данных ──────────────────────────────────────
  // Все относительные пути этапов собираются под этим каталогом:
  // works/output, works/documents, works/cells, works/OutputJson и т.д.
  // Абсолютный путь в настройке этапа игнорирует WorkRoot.
  "WorkRoot": "works",

  // ── Логирование (NLog) ────────────────────────────────────────────────
  // Все приложения пишут в консоль и в logs/<приложение>.log рядом с exe.
  // Файл ротируется по archiveAboveSize (20 МБ), хранится не более
  // maxArchiveFiles частей; при старте прошлые логи удаляются.
  "NLog": {
    "throwConfigExceptions": true,
    "variables": {
      // [ЧЧ:мм:сс] [УРОВЕНЬ] сообщение — уровень опускается для Info,
      // чтобы не зашумлять массовый построчный вывод.
      "line": "[${date:format=HH\\:mm\\:ss}]${when:when=level>LogLevel.Info:inner= [${uppercase:${level}}]} ${message}${onexception:${newline}${exception:format=tostring}}"
    },
    "targets": {
      "console": {
        "type": "ColoredConsole",
        "layout": "${line}",
        "rowHighlightingRules": [
          { "condition": "level == LogLevel.Warn", "foregroundColor": "Yellow" },
          { "condition": "level == LogLevel.Error", "foregroundColor": "Red" },
          { "condition": "contains(message, '[SKIP]')", "foregroundColor": "DarkGray" }
        ]
      },
      "file": {
        "type": "AsyncWrapper",
        "overflowAction": "Block",
        "target": {
          "type": "File",
          "fileName": "${basedir}/logs/${processname}.log",
          "layout": "${line}",
          "archiveAboveSize": 20971520,
          "maxArchiveFiles": 10,
          "deleteOldFileOnStartup": true
        }
      }
    },
    "rules": {
      "0": { "logger": "*", "minLevel": "Info", "writeTo": "console,file" }
    }
  },

  // ── Этап 1: сбор страниц с fp.crc.ru ──────────────────────────────────
  "GetSiteData": {
    "Search": {
      // Термины поиска. Список построен замерами по реестру (март 2025 +
      // объёмы по всей истории): даёт +13,6 % документов к прежним пяти
      // «базов»-терминам, ~92 % новинок — настоящие БС, остальное отсеет
      // ML-классификатор. Поиск сайта понимает wildcard «*» (все словоформы
      // одним термином) и различает кириллицу/латиницу — поэтому аббревиатуры
      // и бренды продублированы в обоих алфавитах (МТС/МТC/MTC, BTS/BТS/ВТС,
      // Скартел*/Cкартел*, К-телеком*/K-телеком*): такие опечатки реально
      // встречаются в реестре, и документы с ними находятся только так.
      "Terms": [
        "базов*", "базав*", "базв*",
        "радиотелефон*", "сотов*", "GSM*", "LTE*", "ПРТО", "РЭС",
        "BTS", "BТS",
        "МТС", "МТC", "MTC", "MTS",
        "МегаФон", "Вымпел*", "Мобайл", "Теле2", "Tele2*", "Билайн",
        "Ростелеком*", "К-телеком*", "K-телеком*",
        "Скартел*", "Cкартел*", "ЕКАТЕРИНБУРГ*"
      ],
      // Период сбора в формате ММ.ГГГГ (включительно).
      // Одинаковые значения — собираем один месяц.
      "PeriodStart": "01.2024",
      "PeriodEnd": "07.2026"
    },
    "OutputPath": "output",
    "Processing": {
      "ResultsPerPage": 50,
      "Parallelism": 4,
      "MaxAttempts": 5,
      "RequestTimeoutSeconds": 60
    }
  },

  // ── Этап 2: HTML → тексты документов ──────────────────────────────────
  "ParseHTML": {
    "InputPath": "output",
    "DocumentsPath": "documents"
  },

  // ── Этап 3: ML-классификация «базовая станция / прочее» ───────────────
  "MLTextToData": {
    "InputRoot": "documents",
    "CellsOutputRoot": "cells",
    "NonCellsOutputRoot": "other",
    "DatabasePath": "data/state.db",
    "ModelPath": "data/model.zip",
    "ParallelDegree": 8,
    "PredictionThreshold": 0.6
  },

  // ── Этап 4: извлечение данных в JSON ─────────────────────────────────
  "ParseTextHeader": {
    // Вход — только документы о базовых станциях (выход классификатора).
    "InputBasePath": "cells",
    "OutputJsonPath": "OutputJson",
    "OutputErrorsPath": "OutputErrors",
    "Processing": {
      "LinesToRead": 12
    },
    // Нормализация адресов через Dadata. Ключи задавайте здесь, переменными
    // окружения (ParseTextHeader__Dadata__Token) или через user-secrets.
    "Dadata": {
      "Enabled": false,
      "Token": "",
      "Secret": ""
    }
  }
}
